@* 
    AddServiceRecordModal Component
    Large modal for creating service records with service items.
    Supports all record types: service, odometer, inspection, note.
    
    Usage:
    <AddServiceRecordModal @ref="_addServiceModal" 
        VehicleId="VehicleId"
        CurrentMiles="_vehicle.CurrentMiles"
        TrackHours="_vehicle.TrackHours"
        OnRecordAdded="HandleRecordAdded" />
*@

@using BlazorApp2.Data.Models
@using BlazorApp2.Services
@inject ServiceRecordService ServiceRecordService
@inject AuthenticationStateProvider AuthenticationStateProvider

<Modal @ref="_modal" Title="@ModalTitle" Size="Modal.ModalSize.ExtraLarge" ShowCloseButton="true" 
       CenterBody="false" AdditionalClass="service-record-modal" OnClose="HandleModalClose">
    <HeaderIcon>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
        </svg>
    </HeaderIcon>
    <Body>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
                @_errorMessage
                <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
            </div>
        }

        @* ── Record Type Selector ── *@
        <div class="sr-type-selector">
            @foreach (var type in RecordType.All)
            {
                <button class="sr-type-btn @(type == _record.RecordType ? "active" : "")"
                        @onclick="() => SetRecordType(type)"
                        type="button"
                        disabled="@_isSaving">
                    <span class="sr-type-icon">
                        @switch (type)
                        {
                            case RecordType.Service:
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M.102 2.223A3.004 3.004 0 0 0 3.78 5.897l6.341 6.252A3.003 3.003 0 0 0 13 16a3 3 0 1 0-.851-5.878L5.897 3.781A3.004 3.004 0 0 0 2.223.1l2.141 2.142L4 4l-1.757.364L.102 2.223zm13.37 9.019.528.026.287.445.445.287.026.529L15 13l-.242.471-.026.529-.445.287-.287.445-.529.026L13 15l-.471-.242-.529-.026-.287-.445-.445-.287-.026-.529L11 13l.242-.471.026-.529.445-.287.287-.445.529-.026L13 11l.471.242z"/>
                                </svg>
                                break;
                            case RecordType.Odometer:
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4zM3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707zM2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10zm9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5zm.754-4.246a.389.389 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.389.389 0 0 0-.029-.518z"/>
                                    <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A7.988 7.988 0 0 1 0 10zm8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3z"/>
                                </svg>
                                break;
                            case RecordType.Inspection:
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0z"/>
                                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                                </svg>
                                break;
                            case RecordType.Note:
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                                    <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2z"/>
                                    <path d="M1 5v-.5a.5.5 0 0 1 1 0V5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0V8h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0v.5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1z"/>
                                </svg>
                                break;
                        }
                    </span>
                    <span class="sr-type-label">@RecordType.GetDisplayName(type)</span>
                </button>
            }
        </div>

        @* ── Form Body (single column, stacked vertically) ── *@
        <div class="sr-form-body sr-form-stacked">
            @* Basic Info Section *@
            <div class="sr-section">
                <h4 class="sr-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                    </svg>
                    Details
                </h4>

                <div class="sr-field">
                    <label for="sr-title">Title</label>
                    <input type="text" id="sr-title" class="form-control"
                           @bind="_record.Title" placeholder="@TitlePlaceholder" disabled="@_isSaving" />
                    <span class="form-hint">Optional short label for this record</span>
                </div>

                <div class="sr-field-row">
                    <div class="sr-field">
                        <label for="sr-date">Date</label>
                        <input type="date" id="sr-date" class="form-control"
                               value="@_record.RecordDate.ToString("yyyy-MM-dd")"
                               @onchange="OnRecordDateChanged" disabled="@_isSaving" />
                    </div>
                    <div class="sr-field">
                        <label for="sr-miles">Odometer (mi)</label>
                        <input type="number" id="sr-miles" class="form-control"
                               @bind="_record.MilesAtService" placeholder="@(CurrentMiles?.ToString("N0") ?? "0")" disabled="@_isSaving" />
                    </div>
                    @if (TrackHours)
                    {
                        <div class="sr-field">
                            <label for="sr-hours">Hours</label>
                            <input type="number" step="0.1" id="sr-hours" class="form-control"
                                   @bind="_record.HoursAtService" placeholder="0.0" disabled="@_isSaving" />
                        </div>
                    }
                </div>

                <div class="sr-field">
                    <label for="sr-notes">Notes</label>
                    <textarea id="sr-notes" class="form-control" rows="2"
                              @bind="_record.Notes" placeholder="Any additional notes..." disabled="@_isSaving"></textarea>
                </div>
            </div>

            @* Shop / Who Section — only for service and inspection types *@
            @if (_record.RecordType is RecordType.Service or RecordType.Inspection)
            {
                <div class="sr-section">
                    <h4 class="sr-section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.707 1.5ZM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5 5 5Z"/>
                        </svg>
                        Where / Who
                        <span class="sr-optional">Optional</span>
                    </h4>
                    <div class="sr-field-row">
                        <div class="sr-field">
                            <label for="sr-shop">Shop Name</label>
                            <input type="text" id="sr-shop" class="form-control"
                                   @bind="_record.ShopName" placeholder="Leave empty for DIY" disabled="@_isSaving" />
                        </div>
                        <div class="sr-field">
                            <label for="sr-tech">Technician</label>
                            <input type="text" id="sr-tech" class="form-control"
                                   @bind="_record.Technician" placeholder="Who did the work?" disabled="@_isSaving" />
                        </div>
                    </div>
                </div>
            }

            @* ── Service Items (only for service records) ── *@
            @if (_record.RecordType == RecordType.Service)
            {
                <div class="sr-section">
                    <div class="sr-section-header-row">
                        <h4 class="sr-section-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                                <path d="M10.97 4.97a.75.75 0 0 1 1.071 1.05l-3.992 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.235.235 0 0 1 .02-.022z"/>
                            </svg>
                            Service Items
                        </h4>
                        <button class="btn btn-sm btn-outline sr-add-item-btn" type="button"
                                @onclick="AddItem" disabled="@_isSaving">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                            </svg>
                            Add Item
                        </button>
                    </div>

                    @if (!_items.Any())
                    {
                        <div class="sr-items-empty">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                                <path d="M10.97 4.97a.75.75 0 0 1 1.071 1.05l-3.992 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.235.235 0 0 1 .02-.022z"/>
                            </svg>
                            <p>No items added yet</p>
                            <span>Add individual tasks like oil change, tire rotation, etc.</span>
                        </div>
                    }
                    else
                    {
                        <div class="sr-items-list">
                            @for (var i = 0; i < _items.Count; i++)
                            {
                                var idx = i;
                                var item = _items[idx];
                                <div class="sr-item-card">
                                    <div class="sr-item-fields">
                                        <div class="sr-item-field-row sr-item-main-row">
                                            <span class="sr-item-number">@(idx + 1)</span>
                                            <div class="sr-field sr-field-grow">
                                                <label>Name</label>
                                                <input type="text" class="form-control"
                                                       @bind="item.Name" placeholder="e.g. Oil & Filter Change" disabled="@_isSaving" />
                                            </div>
                                            <div class="sr-field sr-field-category">
                                                <label>Category</label>
                                                <select class="form-control" @bind="item.Category" disabled="@_isSaving">
                                                    @foreach (var (value, label) in ServiceCategory.All)
                                                    {
                                                        <option value="@value">@label</option>
                                                    }
                                                </select>
                                            </div>
                                            <button class="sr-item-remove" type="button" 
                                                    @onclick="() => RemoveItem(idx)" disabled="@_isSaving"
                                                    title="Remove item">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                                                </svg>
                                            </button>
                                        </div>
                                        <div class="sr-item-field-row">
                                            <div class="sr-field">
                                                <label>Parts $</label>
                                                <input type="number" step="0.01" class="form-control"
                                                       @bind="item.PartsCost" placeholder="0.00" disabled="@_isSaving" />
                                            </div>
                                            <div class="sr-field">
                                                <label>Labor $</label>
                                                <input type="number" step="0.01" class="form-control"
                                                       @bind="item.LaborCost" placeholder="0.00" disabled="@_isSaving" />
                                            </div>
                                            <div class="sr-field">
                                                <label>Next Due (mi)</label>
                                                <input type="number" class="form-control"
                                                       @bind="item.NextDueMiles" placeholder="e.g. @((_record.MilesAtService ?? CurrentMiles ?? 0) + 5000)" disabled="@_isSaving" />
                                            </div>
                                            <div class="sr-field">
                                                <label>Next Due Date</label>
                                                <input type="date" class="form-control"
                                                       value="@(item.NextDueDate?.ToString("yyyy-MM-dd") ?? "")"
                                                       @onchange="(e) => OnItemNextDueDateChanged(e, idx)" disabled="@_isSaving" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* Auto-calculated totals from items *@
                        <div class="sr-items-totals">
                            <div class="sr-totals-row">
                                <span class="sr-totals-label">Parts</span>
                                <span class="sr-totals-value">@ItemsPartsCost.ToString("C")</span>
                            </div>
                            <div class="sr-totals-row">
                                <span class="sr-totals-label">Labor</span>
                                <span class="sr-totals-value">@ItemsLaborCost.ToString("C")</span>
                            </div>
                            <div class="sr-totals-row sr-totals-grand">
                                <span class="sr-totals-label">Total</span>
                                <span class="sr-totals-value">@ItemsTotalCost.ToString("C")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </Body>
    <Footer>
        <div class="sr-footer-left">
            @if (_record.RecordType == RecordType.Service && _items.Any())
            {
                <span class="sr-item-count">@_items.Count item@(_items.Count != 1 ? "s" : "") · @ItemsTotalCost.ToString("C")</span>
            }
        </div>
        <div class="sr-footer-right">
            <button class="btn btn-secondary" @onclick="Close" disabled="@_isSaving" type="button">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveRecord" disabled="@_isSaving" type="button">
                @if (_isSaving)
                {
                    <span class="spinner spinner-sm"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z"/>
                    </svg>
                    <span>Save Record</span>
                }
            </button>
        </div>
    </Footer>
</Modal>

@code {
    [Parameter] public long VehicleId { get; set; }
    [Parameter] public int? CurrentMiles { get; set; }
    [Parameter] public bool TrackHours { get; set; }
    [Parameter] public EventCallback<ServiceRecord> OnRecordAdded { get; set; }

    private Modal? _modal;
    private ServiceRecord _record = new();
    private List<ServiceItem> _items = new();
    private string? _errorMessage;
    private bool _isSaving;

    // Auto-calculated totals from service items
    private decimal ItemsPartsCost => _items.Sum(i => i.PartsCost.GetValueOrDefault());
    private decimal ItemsLaborCost => _items.Sum(i => i.LaborCost.GetValueOrDefault());
    private decimal ItemsTotalCost => ItemsPartsCost + ItemsLaborCost;

    // Date input change handlers (Blazor can't @bind DateOnly to <input type="date"> directly)
    private void OnRecordDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
            _record.RecordDate = date;
    }

    private void OnItemNextDueDateChanged(ChangeEventArgs e, int index)
    {
        if (index >= 0 && index < _items.Count)
        {
            if (DateOnly.TryParse(e.Value?.ToString(), out var date))
                _items[index].NextDueDate = date;
            else
                _items[index].NextDueDate = null;
        }
    }

    private string ModalTitle => _record.RecordType switch
    {
        RecordType.Service => "New Service Record",
        RecordType.Odometer => "Log Odometer Reading",
        RecordType.Inspection => "Log Inspection",
        RecordType.Note => "Add Note",
        _ => "New Record"
    };

    private string TitlePlaceholder => _record.RecordType switch
    {
        RecordType.Service => "e.g. 60k Service, Oil Change",
        RecordType.Odometer => "e.g. Road trip home, End of month",
        RecordType.Inspection => "e.g. Annual state inspection",
        RecordType.Note => "e.g. Heard rattling noise from front",
        _ => "Short description"
    };

    public void Show()
    {
        ResetForm();
        _modal?.Show();
    }

    public void Close()
    {
        _modal?.Hide();
    }

    private void HandleModalClose()
    {
        ResetForm();
    }

    private void ResetForm()
    {
        _record = new ServiceRecord
        {
            VehicleId = VehicleId,
            RecordType = RecordType.Service,
            RecordDate = DateOnly.FromDateTime(DateTime.Today),
            MilesAtService = CurrentMiles
        };
        _items = new List<ServiceItem>();
        _errorMessage = null;
        _isSaving = false;
    }

    private void SetRecordType(string type)
    {
        _record.RecordType = type;
        // If switching away from service, clear items
        if (type != RecordType.Service)
        {
            _items.Clear();
        }
    }

    private void AddItem()
    {
        _items.Add(new ServiceItem
        {
            Category = ServiceCategory.Other,
            Status = ItemStatus.Replaced,
            Name = string.Empty
        });
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < _items.Count)
            _items.RemoveAt(index);
    }

    private async Task SaveRecord()
    {
        _errorMessage = null;

        // Validation
        if (_record.RecordType == RecordType.Odometer && !_record.MilesAtService.HasValue && !_record.HoursAtService.HasValue)
        {
            _errorMessage = "Odometer records need at least a mileage or hours reading.";
            return;
        }

        if (_record.RecordType == RecordType.Service && _items.Any(i => string.IsNullOrWhiteSpace(i.Name)))
        {
            _errorMessage = "All service items need a name.";
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrEmpty(userId))
            {
                _errorMessage = "Unable to identify current user.";
                return;
            }

            // Sum costs from items into the record-level fields (DB computes total_cost)
            _record.PartsCost = ItemsPartsCost > 0 ? ItemsPartsCost : null;
            _record.LaborCost = ItemsLaborCost > 0 ? ItemsLaborCost : null;

            // Attach items to record
            _record.Items = _items;
            _record.VehicleId = VehicleId;

            var saved = await ServiceRecordService.AddServiceRecordAsync(_record, userId);
            await OnRecordAdded.InvokeAsync(saved);
            Close();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving service record: {ex.Message}");
            _errorMessage = "Failed to save record. Please try again.";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
}
